@baseUrl = http://localhost:8080
@token = REPLACE_WITH_TOKEN

### 健康检查
GET {{baseUrl}}/api/healthz

### 登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

### 供货商列表
GET {{baseUrl}}/api/suppliers

### 供货商详情
GET {{baseUrl}}/api/suppliers/1

### 创建供货商 (需 token)
POST {{baseUrl}}/api/suppliers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "TEST-SUPPLIER-20260324-A",
  "contact_person": "赵六六",
  "phone": "13800000006",
  "email": "ftest-supplier@example.com",
  "address": "广州市天河区"
}

### 物料列表
GET {{baseUrl}}/api/materials

### 物料详情
GET {{baseUrl}}/api/materials/5

### 创建物料 （需 token）
POST {{baseUrl}}/api/materials
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "code": "MAT-T6-A",
  "name": "阶段6终测物料A",
  "category": "测试分类",
  "unit": "pcs",
  "specification": "for-final-test",
  "supplier_id": 1,
  "quantity": "50",
  "min_stock": "10",
  "max_stock": "100",
  "unit_price": "8.00"
}

### 出入库 - 入库
POST {{baseUrl}}/api/stock/movements
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "material_id": 5,
  "movement_type": "IN",
  "quantity": "73.00",
  "unit_price": "8.00",
  "reference_no": "TEST-IN-OVERSTOCK-01",
  "remark": "应触发高库存预警"
}

### 出入库列表
GET {{baseUrl}}/api/stock/movements

### 预警列表
GET {{baseUrl}}/api/alerts

### 解决预警
POST {{baseUrl}}/api/alerts/8/resolve
Authorization: Bearer {{token}}

### 创建盘点单
POST {{baseUrl}}/api/stocktaking
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "period": "2026-03-os",
  "remark": "盘点导致高库存补测"
}

### 录入盘点明细
POST {{baseUrl}}/api/stocktaking/4/items
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "material_id": 5,
  "book_quantity": "80.00",
  "actual_quantity": "85.00"
}

### 确认盘点
POST {{baseUrl}}/api/stocktaking/4/confirm
Authorization: Bearer {{token}}

### 盘点列表
GET {{baseUrl}}/api/stocktaking

### 盘点详情
GET {{baseUrl}}/api/stocktaking/3

### 月底结存
GET {{baseUrl}}/api/reports/monthly?year=2026&month=3